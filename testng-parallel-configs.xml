<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!-- 
    PARALLEL EXECUTION CONFIGURATIONS
    
    Choose the configuration that works best for your needs:
    
    1. PARALLEL BY METHODS (Recommended for this framework)
       - Runs each @Test method in parallel threads
       - 4 browsers open simultaneously
       - Fastest execution time
    
    2. PARALLEL BY TESTS
       - Runs each <test> block in parallel
       - Create multiple <test> blocks to see the difference
    
    3. PARALLEL BY CLASSES
       - Runs each test class in parallel
       - Use when you have multiple test classes
    
    4. SEQUENTIAL (No parallelization)
       - Runs tests one after another
       - Useful for debugging
-->

<!-- ============================================ -->
<!-- CONFIGURATION 1: PARALLEL BY METHODS (ACTIVE) -->
<!-- ============================================ -->
<suite name="Selenium Framework Suite" parallel="methods" thread-count="4">
  <test name="Landing Page Tests">
    <classes>
      <class name="seleniumcode.com.learn.seleniumframework.LandingpageBase" />
    </classes>
  </test>
</suite>

